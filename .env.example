# =============================================================================
# SurfSense Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual API keys and settings
# NEVER commit the .env file to version control!

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration (Required for orchestrator)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_TEMPERATURE=0.7
AZURE_OPENAI_MAX_TOKENS=2000

# -----------------------------------------------------------------------------
# Tavily Search Configuration (Required for ResearchAgent)
# -----------------------------------------------------------------------------
# Get your free API key at https://tavily.com (1,000 searches/month free)
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5

# -----------------------------------------------------------------------------
# Forecast API Configuration
# -----------------------------------------------------------------------------
# Stormglass API key (optional — falls back to free Open-Meteo if not set)
FORECAST_API_KEY=

# -----------------------------------------------------------------------------
# Skill Level Thresholds
# -----------------------------------------------------------------------------
BEGINNER_MAX_WAVE_HEIGHT=1.5
BEGINNER_MAX_WIND_SPEED=15
INTERMEDIATE_MAX_WAVE_HEIGHT=2.5
INTERMEDIATE_MAX_WIND_SPEED=20
ADVANCED_MAX_WAVE_HEIGHT=5.0
ADVANCED_MAX_WIND_SPEED=30

# -----------------------------------------------------------------------------
# Scoring Mode (Section 3.3.5)
# -----------------------------------------------------------------------------
# rule = deterministic heuristic (default, no model file required)
# ml   = XGBoost model (requires: python -m ml.train first)
SCORING_MODE=rule
ML_MODEL_PATH=ml/models/surf_condition_model.joblib

# -----------------------------------------------------------------------------
# LLM Baseline Evaluation (Section 3.5.2 — optional)
# Only needed when running evaluation/llm_baseline/
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/surfsense.log
