# =============================================================================
# SurfSense Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual API keys and settings
# NEVER commit the .env file to version control!

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration (Required for orchestrator)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_TEMPERATURE=0.7
AZURE_OPENAI_MAX_TOKENS=2000

# -----------------------------------------------------------------------------
# LLM Configuration (Legacy - used if Azure OpenAI is not configured)
# -----------------------------------------------------------------------------
# LLM Provider: 'local' for free Hugging Face models, 'openai' for OpenAI API
LLM_PROVIDER=local

# Model name: Hugging Face model path or OpenAI model name
LLM_MODEL_NAME=microsoft/Phi-3-mini-4k-instruct

# OpenAI API key (only required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# LLM Generation settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# Force CPU for local models (set to true if no GPU available)
LLM_USE_CPU=false

# -----------------------------------------------------------------------------
# Forecast API Configuration
# -----------------------------------------------------------------------------
# Choose your forecast data provider (surfline, stormglass, etc.)
FORECAST_API_PROVIDER=stormglass
FORECAST_API_KEY=
FORECAST_API_BASE_URL=https://api.stormglass.io/v2

# Forecast cache settings (in seconds)
FORECAST_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
SESSION_TIMEOUT_MINUTES=30

# -----------------------------------------------------------------------------
# Skill Level Thresholds
# -----------------------------------------------------------------------------
BEGINNER_MAX_WAVE_HEIGHT=1.5
BEGINNER_MAX_WIND_SPEED=15
INTERMEDIATE_MAX_WAVE_HEIGHT=2.5
INTERMEDIATE_MAX_WIND_SPEED=20
ADVANCED_MAX_WAVE_HEIGHT=5.0
ADVANCED_MAX_WIND_SPEED=30

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/surfsense.log

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_LOCAL_FORECAST_FALLBACK=true
ENABLE_CACHING=true
ENABLE_API_RATE_LIMITING=true
