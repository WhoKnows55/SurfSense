# =============================================================================
# SurfSense Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual API keys and settings
# NEVER commit the .env file to version control!

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# OpenAI API key for conversational agent
OPENAI_API_KEY=your_openai_api_key_here

# LLM Model settings
LLM_MODEL_NAME=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# -----------------------------------------------------------------------------
# Forecast API Configuration
# -----------------------------------------------------------------------------
# Choose your forecast data provider (surfline, stormglass, etc.)
FORECAST_API_PROVIDER=surfline
FORECAST_API_KEY=your_forecast_api_key_here
FORECAST_API_BASE_URL=https://api.example.com

# Forecast cache settings (in seconds)
FORECAST_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment (development, production)
ENVIRONMENT=development

# API Server settings
API_HOST=0.0.0.0
API_PORT=8000

# Session timeout (in minutes)
SESSION_TIMEOUT_MINUTES=30

# -----------------------------------------------------------------------------
# Skill Level Thresholds
# -----------------------------------------------------------------------------
# Beginner level conditions
BEGINNER_MAX_WAVE_HEIGHT=1.5
BEGINNER_MAX_WIND_SPEED=15

# Intermediate level conditions
INTERMEDIATE_MAX_WAVE_HEIGHT=2.5
INTERMEDIATE_MAX_WIND_SPEED=20

# Advanced level conditions
ADVANCED_MAX_WAVE_HEIGHT=5.0
ADVANCED_MAX_WIND_SPEED=30

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/surfsense.log

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_LOCAL_FORECAST_FALLBACK=true
ENABLE_CACHING=true
ENABLE_API_RATE_LIMITING=true
